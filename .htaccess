Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow static and API files to work when the app is served under /tuintips.
    RewriteRule ^tuintips/(assets/.+)$ $1 [L]
    RewriteRule ^tuintips/(api/.+)$ $1 [L]

    # Keep direct access to real files and directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route pretty URLs through index.php.
    RewriteRule ^ index.php [QSA,L]
</IfModule>
